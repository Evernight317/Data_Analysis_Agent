# Data Analysis Agent - 环境变量配置
# 复制此文件为 .env 并填入实际值

# --- Anthropic API ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# --- Model ---
MODEL_NAME=claude-sonnet-4-6
MAX_TOKENS=4096

# --- Agent ---
MAX_TURNS=20

# --- Output ---
OUTPUT_DIR=output
CHART_FORMAT=png
CHART_DPI=150

# --- Chinese Font (Windows) ---
CHINESE_FONT=Microsoft YaHei
